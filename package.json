{
  "name": "@jfairbairn/pi-bdd",
  "version": "0.4.1",
  "description": "Agentic software delivery system: outside-in BDD enforcement, security scanning, staged deployment, and product measurement for the pi coding agent",
  "keywords": [
    "pi-package",
    "bdd",
    "tdd",
    "agentic",
    "software-delivery"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfairbairn/pi-bdd.git"
  },
  "author": "James Fairbairn",
  "license": "MIT",
  "scripts": {
    "test": "vitest run --reporter=verbose"
  },
  "pi": {
    "extensions": [
      "./extensions/**/*.ts",
      "!./extensions/**/*.test.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  },
  "bugs": {
    "url": "https://github.com/jfairbairn/pi-bdd/issues"
  },
  "homepage": "https://github.com/jfairbairn/pi-bdd#readme"
}
